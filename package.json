{
  "name": "effect-start",
  "private": true,
  "scripts": {
    "prepare": "effect-language-service patch",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "check-types": "turbo check-types",
    "test": "turbo run test",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "bun --env-file .env packages/persistence/src/cli/migrate.ts",
    "db:seed": "bun --env-file .env packages/persistence/src/cli/seed.ts",
    "db:setup": "bun run db:up && bun run db:migrate && bun run db:seed"
  },
  "devDependencies": {
    "@effect/language-service": "^0.84.2",
    "@vitest/coverage-istanbul": "catalog:",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.43.0",
    "oxlint-tsgolint": "^0.19.0",
    "turbo": "^2.9.3",
    "typescript": "6.0.2",
    "vitest": "^4.0.18"
  },
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "@effect/language-service": "^0.84.2",
    "@effect/vitest": "4.0.0-beta.43",
    "@tanstack/react-router": "^1.147.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-istanbul": "^4.0.18",
    "effect": "4.0.0-beta.43",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsdown": "^0.21.7",
    "typescript": "6.0.2",
    "vite": "^8.0.3",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
