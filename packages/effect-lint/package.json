{
  "name": "@starter/effect-lint",
  "version": "0.1.0",
  "private": true,
  "description": "Oxlint JS plugin for Effect lint rules (alternative API)",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": "./src/index.js",
    "./rules": "./src/rules/index.js",
    "./configs": "./src/configs.js"
  },
  "files": [
    "src",
    "configs",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "bun test tests/run-oxlint.test.mjs",
    "format": "oxfmt -c ../../.oxfmtrc.json --write src/",
    "format:check": "oxfmt -c ../../.oxfmtrc.json --check src/"
  },
  "dependencies": {
    "oxlint": "^1.42.0"
  }
}
