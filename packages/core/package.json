{
  "name": "@starter/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./todo/TodoId": "./src/todo/TodoId.ts",
    "./todo/Todo": "./src/todo/Todo.ts",
    "./todo/CreateTodoInput": "./src/todo/CreateTodoInput.ts",
    "./todo/UpdateTodoInput": "./src/todo/UpdateTodoInput.ts"
  },
  "scripts": {
    "test": "vitest --run",
    "check-types": "tsc --noEmit",
