{
  "name": "@starter/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./button": {
      "types": "./dist/button.d.ts",
      "default": "./dist/button.js"
    },
    "./card": {
      "types": "./dist/card.d.ts",
      "default": "./dist/card.js"
    },
    "./code": {
      "types": "./dist/code.d.ts",
      "default": "./dist/code.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "lint": "oxlint --type-aware --max-warnings 0 .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tsdown": "^0.20.1",
    "typescript": "catalog:"
  },
  "dependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
