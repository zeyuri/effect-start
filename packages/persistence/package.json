{
  "name": "@starter/persistence",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./Errors/RepositoryError": "./src/Errors/RepositoryError.ts",
    "./Schema/TodoRow": "./src/Schema/TodoRow.ts",
    "./Services/TodoRepository": "./src/Services/TodoRepository.ts",
    "./Layers/DbLive": "./src/Layers/DbLive.ts",
    "./Layers/MigrationsLive": "./src/Layers/MigrationsLive.ts",
    "./Layers/TodoRepositoryLive": "./src/Layers/TodoRepositoryLive.ts",
    "./Layers/RepositoriesLive": "./src/Layers/RepositoriesLive.ts",
    "./Migrations": "./src/Migrations/index.ts"
  },
  "scripts": {
    "migrate": "bun src/cli/migrate.ts",
    "seed": "bun src/cli/seed.ts",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "lint": "oxlint --type-aware -c ../../.oxlintrc.json src/",
    "format": "oxfmt -c ../../.oxfmtrc.json --write src/",
    "format:check": "oxfmt -c ../../.oxfmtrc.json --check src/"
  },
  "dependencies": {
    "@starter/core": "workspace:*",
    "@effect/platform": "catalog:",
    "@effect/sql": "^0.49.0",
    "@effect/sql-pg": "^0.50.1",
    "effect": "catalog:",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/vitest": "catalog:",
    "@starter/vitest-config": "workspace:*",
    "@testcontainers/postgresql": "^11.11.0",
    "@types/node": "^25.2.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
